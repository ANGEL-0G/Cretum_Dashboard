{
  "version": 2,
  "builds": [
    { "src": "public/index.html",   "use": "@vercel/static" },
    { "src": "public/portal.html",  "use": "@vercel/static" },
    { "src": "public/portal-mvp.html", "use": "@vercel/static" },
    { "src": "public/app.js",       "use": "@vercel/static" },
    { "src": "public/logo.png",     "use": "@vercel/static" },
    { "src": "public/logo-icon.png", "use": "@vercel/static" },
    { "src": "public/logo-mvp.png",  "use": "@vercel/static" },
    { "src": "api/tasks.js",             "use": "@vercel/node" },
    { "src": "api/reminder.js",          "use": "@vercel/node" },
    { "src": "api/config.js",            "use": "@vercel/node" },
    { "src": "api/dropbox.js",           "use": "@vercel/node" },
    { "src": "api/sheets.js",            "use": "@vercel/node" },
    { "src": "api/portal.js",            "use": "@vercel/node" },
    { "src": "api/notify-assignment.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/tasks",              "dest": "/api/tasks.js" },
    { "src": "/api/reminder",           "dest": "/api/reminder.js" },
    { "src": "/api/config",             "dest": "/api/config.js" },
    { "src": "/api/dropbox",            "dest": "/api/dropbox.js" },
    { "src": "/api/sheets",             "dest": "/api/sheets.js" },
    { "src": "/api/portal",             "dest": "/api/portal.js" },
    { "src": "/api/notify-assignment",  "dest": "/api/notify-assignment.js" },
    { "src": "/portal-mvp",    "dest": "/public/portal-mvp.html" },
    { "src": "/portal",        "dest": "/public/portal.html" },
    { "src": "/app.js",        "dest": "/public/app.js" },
    { "src": "/logo.png",      "dest": "/public/logo.png" },
    { "src": "/logo-icon.png", "dest": "/public/logo-icon.png" },
    { "src": "/logo-mvp.png",  "dest": "/public/logo-mvp.png" },
    { "src": "/(.*)",          "dest": "/public/index.html" }
  ]
}
